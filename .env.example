# Kopieer dit bestand naar `.env` als je iets wil aanpassen.
# Standaardwaarden zijn prima voor lokaal gebruik.

# Welke poort op de host (default 3000).
UI_PORT=3000

# Welke interface luistert.
# 127.0.0.1 = alleen jouw eigen machine (default, veiligst).
# Voor delen via Tailscale: zet hier het Tailscale-IP
# (output van `tailscale ip -4`).
UI_BIND=127.0.0.1
