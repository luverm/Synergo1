# Kopieer dit bestand naar `.env` en pas waarden aan.
# `.env` staat in .gitignore en mag NOOIT in git komen.

# Gedeelde API key tussen frontend en backend.
# Genereer met: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY=vervang-mij-met-een-sterke-random-string

# Ollama modellen
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# Frontend
UI_PORT=8501

# Interface waarop de UI luistert.
# 127.0.0.1 = alleen jouw eigen machine (default, veiligst).
# Voor delen met collega's via Tailscale: zet hier het Tailscale-IP
# van deze machine (output van `tailscale ip -4`).
UI_BIND=127.0.0.1

# CORS - laat staan voor lokaal gebruik
ALLOWED_ORIGINS=http://localhost:8501

# Upload limiet in MB
MAX_UPLOAD_MB=25
